#!/bin/zsh
# set -x

DOTFILES_DIR="$(cd "$(dirname "$0")" && pwd)"

CONFIG_DIR="${XDG_DATA_HOME:-${HOME}/.config}"

# # (.) at end tells zsh to only return files
# for file in $DOTFILES_DIR/.*(.); do
#     echo ln -s $file `basename $file`
# done
#
# for dir in $DOTFILES_DIR/*(/); do
#     echo $dir
# done
#

cd ~

DOTFILES=(zim/.zshrc zim/.zimrc .wezterm.lua .ripgreprc)

for file in $DOTFILES; do
    link_name=$(basename "$file")
    ln -snf $DOTFILES_DIR/$file $link_name
done

DOTFILE_DIRS=(nvim stylua eza)

for dir in $DOTFILE_DIRS; do
    ln -snf $DOTFILES_DIR/$dir $CONFIG_DIR/$dir
done

# Config files with directory creation - format: source[:destination]
# If destination is omitted, uses source as destination
CONFIG_FILES=(
    agents/AGENTS.md:opencode/AGENTS.md
    hunk/config.toml
    tmux/tmux.conf
)

for entry in $CONFIG_FILES; do
    if [[ "$entry" == *:* ]]; then
        source="${entry%%:*}"
        dest="${entry##*:}"
    else
        source="$entry"
        dest="$entry"
    fi
    dest_dir="$CONFIG_DIR/$(dirname "$dest")"
    mkdir -p "$dest_dir"
    ln -snf "$DOTFILES_DIR/$source" "$CONFIG_DIR/$dest"
done
