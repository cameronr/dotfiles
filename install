#!/bin/zsh
# set -x

DOTFILES_DIR="$(cd "$(dirname "$0")" && pwd)"

CONFIG_DIR="${XDG_DATA_HOME:-${HOME}/.config}"

cd ~

DOTFILES=(zim/.zshrc zim/.zimrc .wezterm.lua .ripgreprc)

for file in $DOTFILES; do
    link_name=$(basename "$file")
    ln -snf $DOTFILES_DIR/$file $link_name
done

DIR_SYMLINKS=(nvim stylua eza)

for dir in $DIR_SYMLINKS; do
    ln -snf $DOTFILES_DIR/$dir $CONFIG_DIR/$dir
done

# Symlink files with directory creation - format: source[:destination]
# If destination is omitted, uses source as destination
# Destination is relative to CONFIG_DIR by default, unless prefixed with ~/ in which
# case it's relative to HOME instead (for tools that don't use CONFIG_DIR)
FILE_SYMLINKS=(
    agents/AGENTS.md:opencode/AGENTS.md
    "agents/AGENTS.md:~/.pi/agent/AGENTS.md"
    hunk/config.toml
    tmux/tmux.conf
    herdr/config.toml
)

for entry in $FILE_SYMLINKS; do
    if [[ "$entry" == *:* ]]; then
        source="${entry%%:*}"
        dest="${entry##*:}"
    else
        source="$entry"
        dest="$entry"
    fi
    if [[ "$dest" == "~/"* ]]; then
        dest_path="${HOME}/${dest#\~/}"
    else
        dest_path="$CONFIG_DIR/$dest"
    fi
    mkdir -p "$(dirname "$dest_path")"
    ln -snf "$DOTFILES_DIR/$source" "$dest_path"
done
